[sub_resource type="Shader" id="Shader_blur_darken"]
code = "shader_type canvas_item;\n\nuniform sampler2D screen_tex : hint_screen_texture, filter_linear_mipmap;\nuniform float blur_lod = 3.5;\nuniform float dim_strength = 0.5;\n\nvoid fragment() {\n\tvec4 col = textureLod(screen_tex, SCREEN_UV, blur_lod);\n\tcol.rgb *= (1.0 - dim_strength);\n\tCOLOR = col;\n}\n"

